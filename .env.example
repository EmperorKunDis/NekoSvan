# NekoSvan CRM - Environment Variables
# Copy this file to .env and fill in the values

# Django
DJANGO_SECRET_KEY=your-super-secret-key-change-this-in-production
DJANGO_SETTINGS_MODULE=config.settings.production

# Database
DB_NAME=nekosvan
DB_USER=nekosvan
DB_PASSWORD=your-secure-database-password
DB_HOST=db
DB_PORT=5432

# Hosts
ALLOWED_HOSTS=localhost,127.0.0.1,praut.cz,www.praut.cz,app.praut.cz
CORS_ALLOWED_ORIGINS=https://praut.cz,https://www.praut.cz
CSRF_TRUSTED_ORIGINS=https://praut.cz,https://www.praut.cz

# ONLYOFFICE
ONLYOFFICE_URL=http://onlyoffice

# N8N Webhooks (optional)
N8N_WEBHOOK_BASE_URL=http://localhost:5678/webhook

# Sentry (optional)
SENTRY_DSN=
